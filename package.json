{
  "name": "droid-patch",
  "version": "0.14.0",
  "description": "CLI tool to patch droid binary with various modifications",
  "keywords": [
    "binary",
    "cli",
    "droid",
    "patch"
  ],
  "homepage": "https://github.com/kingsword09/droid-patch#readme",
